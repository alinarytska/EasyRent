# Django
SECRET_KEY=change-me-docker-local-secret-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SERVE_MEDIA_FILES=True

# Security for local Docker run
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_REFERRER_POLICY=same-origin

# Logging
LOG_LEVEL=INFO
HTTP_LOG_LEVEL=WARNING
DB_LOG_LEVEL=WARNING

# Database
USE_REMOTE=True
MYSQL_DATABASE=easyrent
MYSQL_NAME=easyrent
MYSQL_USER=easyrent
MYSQL_PASSWORD=easyrent_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST=db
MYSQL_PORT=3306

# Optional superuser creation on container startup
CREATE_SUPERUSER_ON_STARTUP=False
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=StrongAdminPassword123!
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=User

# Optional seed data on container startup
SEED_DATA_ON_STARTUP=False
SEED_DATA_ARGS=
