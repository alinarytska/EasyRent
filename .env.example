SECRET_KEY=replace-with-a-secure-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Security settings.
# Keep these values for local HTTP development.
# For production with HTTPS, set the secure cookie values and SSL redirect to True.
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_REFERRER_POLICY=same-origin

# Logging settings.
LOG_LEVEL=INFO
HTTP_LOG_LEVEL=WARNING
DB_LOG_LEVEL=WARNING

# API throttling settings.
THROTTLE_AUTH_RATE=10/min
THROTTLE_AUTH_REFRESH_RATE=20/min
THROTTLE_REGISTRATION_RATE=5/min
THROTTLE_LISTINGS_RATE=120/min
THROTTLE_HISTORY_RATE=120/min
THROTTLE_POPULAR_RATE=60/min

# False uses local SQLite; True uses MySQL settings below.
USE_REMOTE=False

MYSQL_NAME=easyrent
MYSQL_USER=easyrent
MYSQL_PASSWORD=replace-with-a-secure-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
